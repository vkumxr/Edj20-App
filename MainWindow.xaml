<Window x:Class="Edj20Tester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:Edj20Tester.Models"
        mc:Ignorable="d"
        Title="EDJ20 TESTING SYSTEM"
        Height="760" Width="1380"
        Background="#1E1E1E">

    <Window.Resources>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"  Value="#111111"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="8,6"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#00AAAA"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="#111111"/>
            <Setter Property="Foreground"  Value="Black"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#111111"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background"      Value="#111111"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="REQUEST  /  RESPONSE  TESTING"
                   Foreground="Lime"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <!-- TCP CONNECTION ROW -->
        <Border Grid.Row="1"
                Background="#111111"
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,8"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="IP Address:"
                           Foreground="#AAAAAA"
                           FontFamily="Consolas"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox Name="TxtIpAddress"
                         Width="160" Height="34"
                         Text="192.168.1.100"
                         Margin="0,0,14,0"/>

                <TextBlock Text="Port:"
                           Foreground="#AAAAAA"
                           FontFamily="Consolas"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox Name="TxtPort"
                         Width="70" Height="34"
                         Text="502"
                         Margin="0,0,16,0"/>

                <Button Name="btnConnect"
                        Click="btnConnect_Click"
                        Content="CONNECT"
                        Width="110" Height="34"
                        Foreground="#00CCFF"
                        BorderBrush="#00CCFF"
                        Margin="0,0,10,0"
                        Style="{StaticResource DarkButton}"/>

                <Button Name="btnDisconnect"
                        Click="btnDisconnect_Click"
                        Content="DISCONNECT"
                        Width="120" Height="34"
                        Foreground="#FF9900"
                        BorderBrush="#FF9900"
                        IsEnabled="False"
                        Margin="0,0,20,0"
                        Style="{StaticResource DarkButton}"/>

                <!-- TCP connection status pill -->
                <Border CornerRadius="6"
                        Padding="10,4"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#330000"/>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Name="TcpDot"
                                 Width="10" Height="10"
                                 Fill="#FF3333"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0"/>
                        <TextBlock Name="TcpStatusText"
                                   Text="TCP : DISCONNECTED"
                                   Foreground="#FF3333"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- TOP CONTROLS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    Margin="0,0,0,12" VerticalAlignment="Center">

            <TextBlock Text="Function:"
                       Foreground="#AAAAAA"
                       FontSize="13"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox Name="FunctionSelector"
                      Width="280" Height="40"
                      SelectedIndex="0"
                      Margin="0,0,12,0"
                      VerticalContentAlignment="Center">
                <ComboBoxItem Content="FC03 – Read Holding Registers"
                              Tag="{x:Static models:ModbusFunction.FC03_ReadHoldingRegisters}"/>
                <ComboBoxItem Content="FC04 – Read Input Registers"
                              Tag="{x:Static models:ModbusFunction.FC04_ReadInputRegisters}"/>
                <ComboBoxItem Content="FC06 – Write Single Register"
                              Tag="{x:Static models:ModbusFunction.FC06_WriteSingleRegister}"/>
                <ComboBoxItem Content="FC16 – Write Multiple Registers"
                              Tag="{x:Static models:ModbusFunction.FC16_WriteMultipleRegisters}"/>
            </ComboBox>

            <Button Name="btnStart"
                    Click="btnStart_Click"
                    Content="START TEST"
                    Width="140" Height="40"
                    Foreground="Lime"
                    BorderBrush="Lime"
                    IsEnabled="False"
                    Style="{StaticResource DarkButton}"/>

            <Button Name="btnClear"
                    Click="btnClear_Click"
                    Content="CLEAR"
                    Width="90" Height="40"
                    Foreground="#FF5555"
                    BorderBrush="#FF5555"
                    Margin="10,0,0,0"
                    Style="{StaticResource DarkButton}"/>

        </StackPanel>

        <!-- SIDE-BY-SIDE PACKET AREA -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: REQUEST panel -->
            <Border Grid.Column="0"
                    Background="#111111"
                    BorderBrush="#00CCCC"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="REQUEST"
                               Foreground="#00FFFF"
                               FontFamily="Consolas"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    <ScrollViewer Grid.Row="1"
                                  Name="RequestScroller"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <StackPanel Name="RequestPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- CENTRE divider -->
            <Rectangle Grid.Column="1"
                       Width="1"
                       Fill="#333333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Stretch"/>

            <!-- RIGHT: RESPONSE panel -->
            <Border Grid.Column="2"
                    Background="#111111"
                    BorderBrush="#00AA00"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="RESPONSE"
                               Foreground="#00FF00"
                               FontFamily="Consolas"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    <ScrollViewer Grid.Row="1"
                                  Name="ResponseScroller"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <StackPanel Name="ResponsePanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="4"
                Background="#222222"
                CornerRadius="8"
                Padding="12"
                Margin="0,14,0,0">
            <DockPanel>
                <Ellipse Name="StatusDot"
                         Width="12" Height="12"
                         Fill="Lime"
                         Margin="0,0,10,0"
                         VerticalAlignment="Center"/>
                <TextBlock Name="StatusText"
                           Text="STATUS : READY"
                           Foreground="Black"
                           FontFamily="Consolas"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
